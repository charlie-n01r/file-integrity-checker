#!/usr/bin/env zsh
set -euo pipefail

# --- 1. Create data directory and initialize database ---
DATA_DIR="$HOME/.local/share/integrity_check"
DB="$DATA_DIR/hashes.db"

mkdir -p "$DATA_DIR"

chmod 700 "$DATA_DIR"

sqlite3 "$DB" <<EOF
PRAGMA journal_mode=WAL;

CREATE TABLE IF NOT EXISTS files (
    path TEXT PRIMARY KEY,
    hash BLOB NOT NULL
);

CREATE INDEX IF NOT EXISTS idx_files_hash ON files(hash);
EOF

chmod 600 "$DB"

# --- 2. Download binary ---
BIN_NAME="integrity-check"
REPO="YOUR_USER/YOUR_REPO"
URL="https://github.com/charlie-n01r/file-integrity-checker/releases/download/v0.1.2-alpha/integrity-check"

echo "Downloading $BIN_NAME..."
curl -L "$URL" -o "$BIN_NAME"
chmod +x "$BIN_NAME"

# --- 3. Move binary into PATH ---
INSTALL_DIR="${HOME}/.local/bin"
mkdir -p "$INSTALL_DIR"
mv "$BIN_NAME" "$INSTALL_DIR/$BIN_NAME"

echo "Installed $BIN_NAME to $INSTALL_DIR"
echo "Make sure $INSTALL_DIR is in your PATH."

# --- 5. Log directory setup ---
LOG_DIR="$DATA_DIR/log"
mkdir -p "$LOG_DIR"
chmod 2750 "$LOG_DIR"

echo "$BIN_NAME installed successfully!"